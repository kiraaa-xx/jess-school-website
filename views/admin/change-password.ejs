<%- include('../partials/admin-layout-top', { title: 'Password', admin: '' }) %>

<div class="form-card" style="max-width:480px">
  <h2><i class="fa-solid fa-lock"></i> Change Password</h2>

  <% if (error)   { %><div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><i class="fa-solid fa-check"></i> <%= success %></div><% } %>

  <form method="POST" action="/admin/change-password">
    <div class="form-group">
      <label for="current_password">Current Password</label>
      <input type="password" id="current_password" name="current_password" required>
    </div>
    <div class="form-group">
      <label for="new_password">New Password (min. 6 characters)</label>
      <input type="password" id="new_password" name="new_password" required minlength="6">
    </div>
    <div class="form-group">
      <label for="confirm_password">Confirm New Password</label>
      <input type="password" id="confirm_password" name="confirm_password" required minlength="6">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-admin-primary"><i class="fa-solid fa-lock"></i> Change Password</button>
    </div>
  </form>
</div>

<%- include('../partials/admin-layout-bottom') %>
