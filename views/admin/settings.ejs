<%- include('../partials/admin-layout-top', { title: 'Settings', admin: '' }) %>

<% if (success) { %><div class="alert alert-success"><i class="fa-solid fa-check"></i> <%= success %></div><% } %>

<div class="form-card">
  <h2><i class="fa-solid fa-gear"></i> School Information Settings</h2>
  <p style="color:#888;margin-bottom:24px;font-size:.875rem">Changes here will update text across the entire website.</p>

  <form method="POST" action="/admin/settings">

    <h3 class="settings-section-title">Basic Info</h3>
    <div class="form-row">
      <div class="form-group">
        <label>School Full Name</label>
        <input type="text" name="school_name" value="<%= info.school_name %>" maxlength="100">
      </div>
      <div class="form-group">
        <label>Short Name</label>
        <input type="text" name="school_short" value="<%= info.school_short %>" maxlength="20">
      </div>
    </div>
    <div class="form-group">
      <label>Tagline / Motto</label>
      <input type="text" name="tagline" value="<%= info.tagline %>" maxlength="100">
    </div>
    <div class="form-group">
      <label>Hero Title (HTML allowed for &lt;span&gt; highlights)</label>
      <input type="text" name="hero_title" value="<%= info.hero_title %>" maxlength="200">
    </div>
    <div class="form-group">
      <label>About Text</label>
      <textarea name="about_text" rows="4" maxlength="1000"><%= info.about_text %></textarea>
    </div>

    <h3 class="settings-section-title">Contact Details</h3>
    <div class="form-row">
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" value="<%= info.phone %>" maxlength="30">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= info.email %>" maxlength="100">
      </div>
    </div>
    <div class="form-group">
      <label>Full Address</label>
      <input type="text" name="address" value="<%= info.address %>" maxlength="300">
    </div>

    <h3 class="settings-section-title">Social &amp; Maps</h3>
    <div class="form-row">
      <div class="form-group">
        <label>Facebook Page URL</label>
        <input type="url" name="facebook_url" value="<%= info.facebook_url %>" maxlength="300">
      </div>
      <div class="form-group">
        <label>Google Maps URL (for "Get Directions" link)</label>
        <input type="url" name="maps_url" value="<%= info.maps_url %>" maxlength="500">
      </div>
    </div>
    <div class="form-group">
      <label>Google Maps Embed URL (for the map iframe src)</label>
      <input type="url" name="maps_embed" value="<%= info.maps_embed %>" maxlength="1000">
    </div>

    <h3 class="settings-section-title">History &amp; Stats</h3>
    <div class="form-row">
      <div class="form-group">
        <label>Founded Year (B.S.)</label>
        <input type="text" name="founded_bs" value="<%= info.founded_bs %>" maxlength="10">
      </div>
      <div class="form-group">
        <label>Founded Year (A.D.)</label>
        <input type="text" name="founded_ad" value="<%= info.founded_ad %>" maxlength="10">
      </div>
      <div class="form-group">
        <label>Total Students Count</label>
        <input type="number" name="students_count" value="<%= info.students_count %>" min="0">
      </div>
    </div>

    <h3 class="settings-section-title">Leadership</h3>
    <div class="form-row">
      <div class="form-group">
        <label>Principal Name</label>
        <input type="text" name="principal_name" value="<%= info.principal_name %>" maxlength="100">
      </div>
      <div class="form-group">
        <label>Vice-Principal Name</label>
        <input type="text" name="vice_principal" value="<%= info.vice_principal %>" maxlength="100">
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-admin-primary"><i class="fa-solid fa-floppy-disk"></i> Save All Settings</button>
    </div>

  </form>
</div>

<%- include('../partials/admin-layout-bottom') %>
